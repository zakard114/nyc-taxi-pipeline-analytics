# ---------------------------------------------------------------------------
# Copy this file to:  local-dev-ui.env   (same folder)
# The copy is gitignored — put your real local UI passwords there only.
#
# Purpose: one place to remember Kestra + Grafana logins for Docker Compose.
# Defaults below match docker-compose.yml in this repo; change both files if you rotate passwords.
# This file does NOT drive docker-compose automatically — it is a personal reminder only.
# ---------------------------------------------------------------------------

# Kestra Web UI (basic auth)
KESTRA_URL=http://localhost:8090
KESTRA_BASIC_AUTH_EMAIL=admin@company.com
KESTRA_BASIC_AUTH_PASSWORD=StrongPass1

# Grafana
GRAFANA_URL=http://localhost:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
