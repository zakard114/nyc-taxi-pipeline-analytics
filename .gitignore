# Repo root — secrets & generated output (do not commit). Works for standalone clone or nested DE/Project.

venv/
.venv/
__pycache__/
*.py[cod]
# History check on repo root: no past commits include paths matching tfstate or credential JSON
# (`git log --all --name-only | findstr /i "tfstate gcp-creds"` returned nothing).

.env
.env.*
!.env.example

# Terraform: local state holds resource IDs; never commit
*.tfstate
*.tfstate.*
.terraform/
crash.log
crash.*.log

# Terraform variable overrides (may contain real project/bucket names)
terraform/terraform.tfvars
terraform/*.auto.tfvars

# GCP service account keys & generic credential JSON (never commit)
# GCP service account key (preferred location — see credentials/README.md)
credentials/gcp-service-account.json
# Local UI reminders (Kestra / Grafana) — copy from local-dev-ui.env.example
credentials/local-dev-ui.env
# Legacy paths (do not use for new setups)
terraform/gcp-creds.json
**/gcp-creds.json
**/google_credentials.json

*.duckdb
*.duckdb.wal

# dbt (rebuild with `dbt run` / `dbt build` — keep out of git)
nyc_taxi_dbt/logs/
nyc_taxi_dbt/target/

# Local TLC / Parquet (large; do not commit)
data/**/*.parquet
data/**/*.csv

# Flink connector JARs (download into flink-libs/ — see docker-compose Flink services)
flink-libs/*.jar

# Accidental local Kestra/Docker artifacts at repo root (optional)
kestra-data/
kestra-db/
